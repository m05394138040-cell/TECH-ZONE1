# ===== TECH ZONE Environment Configuration =====

# Server port (Render sets this automatically)
PORT=3000

# Database connection string
# LOCAL DEV: postgresql://postgres:password@localhost:5432/techzone
# RENDER:   postgresql://user:pass@host/dbname (from Render dashboard)
# SUPABASE: postgresql://postgres.xxxx:pass@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techzone

# JWT Secret (generate a random string for production)
# Example: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-secret-string-in-production-9k3j2h4g

# Admin credentials (used only on FIRST init - changes after don't affect DB)
ADMIN_USERNAME=GH1899
ADMIN_PASSWORD=266641

# Site defaults (used on first init only - changes after don't affect DB)
DEFAULT_WHATSAPP=+962790000000
DEFAULT_SITE_NAME=TECH ZONE