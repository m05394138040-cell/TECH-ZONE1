<%- include('partials/header') %>

<% if (sliderImages && sliderImages.length > 0) { %>
  <section class="hero-slider" id="heroSlider" aria-label="سلايدر العروض">
    <div class="hero-slider-viewport">
      <div class="hero-slider-track" id="heroSliderTrack">
        <% sliderImages.forEach(function(img, i) { %>
          <% if (img.link_url) { %>
            <a class="hero-slider-slide" href="<%= img.link_url %>" data-index="<%= i %>" <%= img.link_url.startsWith('http') ? 'target="_blank" rel="noopener"' : '' %>>
          <% } else { %>
            <div class="hero-slider-slide" data-index="<%= i %>">
          <% } %>
            <img src="/slider-img/<%= img.id %>" alt="<%= img.title || ('عرض ' + (i + 1)) %>" loading="<%= i === 0 ? 'eager' : 'lazy' %>" />
            <% if (img.title) { %>
              <div class="hero-slider-caption"><%= img.title %></div>
            <% } %>
          <% if (img.link_url) { %>
            </a>
          <% } else { %>
            </div>
          <% } %>
        <% }); %>
      </div>
    </div>
  </section>
<% } %>

<section class="hero">
  <img src="/img/logo.png?v=2" alt="<%= siteName %>" class="hero-logo" />
  <p>اكسسوارات الأجهزة الذكية — جميع المنتجات متوفرة بأسعار تنافسية</p>
</section>

<% if (settings.ticker_enabled === 'true' || !settings.ticker_enabled) { %>
  <% if (settings.ticker_text) { %>
    <div class="news-ticker" style="background: <%= settings.ticker_bg_color || '#0a0a0a' %>;">
      <div class="ticker-content" style="color: <%= settings.ticker_color || '#ffffff' %>;">
        <div class="ticker-track">
          <span class="ticker-text"><%= settings.ticker_text %></span>
          <span class="ticker-text"><%= settings.ticker_text %></span>
          <span class="ticker-text"><%= settings.ticker_text %></span>
        </div>
      </div>
    </div>
  <% } %>
<% } %>

<% if (latestProducts && latestProducts.length > 0) { %>
  <section class="latest-products-section" aria-label="أحدث المنتجات">
    <div class="latest-products-header">
      <h2 class="section-title latest-title" id="latest">أحدث المنتجات</h2>

    </div>

    <div class="latest-products-grid">
      <% const nowMs = Date.now(); %>
      <% latestProducts.forEach(function(p) { %>
        <% const dp = displayPrice(p); %>
        <%# Show 'جديد' badge only if product was added within the last 24 hours %>
        <% const createdMs = new Date(p.created_at).getTime(); %>
        <% const ageHours = (nowMs - createdMs) / (1000 * 60 * 60); %>
        <% const isNew = ageHours < 24; %>
        <a href="/product/<%= p.id %>" class="latest-product-card">
          <div class="latest-product-image">
            <% if (p.image_type) { %>
              <img src="/img/<%= p.id %>" alt="<%= p.name %>" loading="lazy" />
            <% } else { %>
              <div class="latest-product-placeholder">📦</div>
            <% } %>
            <% if (isNew) { %>
              <span class="latest-product-badge">جديد</span>
            <% } %>
          </div>
          <div class="latest-product-body">
            <div class="latest-product-name"><%= p.name %></div>
            <div class="latest-product-category">📂 <%= p.category_name %></div>
            <div class="latest-product-price">
              <%= dp.amount %>
              <span class="latest-currency"><%= dp.symbol %></span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>

    <%# Pagination %>
    <% if (totalPages > 1) { %>
      <nav class="latest-pagination" aria-label="تصفح الصفحات">
        <%# Previous %>
        <% if (currentPage > 1) { %>
          <a class="page-btn" href="/?page=<%= currentPage - 1 %>#latest" aria-label="الصفحة السابقة">‹ السابق</a>
        <% } else { %>
          <span class="page-btn disabled" aria-disabled="true">‹ السابق</span>
        <% } %>

        <%# Page numbers — show first, last, current ± 2 %>
        <%
          const pages = [];
          const start = Math.max(1, currentPage - 2);
          const end = Math.min(totalPages, currentPage + 2);
          if (start > 1) {
            pages.push(1);
            if (start > 2) pages.push('...');
          }
          for (let i = start; i <= end; i++) pages.push(i);
          if (end < totalPages) {
            if (end < totalPages - 1) pages.push('...');
            pages.push(totalPages);
          }
        %>
        <% pages.forEach(function(p) { %>
          <% if (p === '...') { %>
            <span class="page-ellipsis">…</span>
          <% } else if (p === currentPage) { %>
            <span class="page-btn active" aria-current="page"><%= p %></span>
          <% } else { %>
            <a class="page-btn" href="/?page=<%= p %>#latest"><%= p %></a>
          <% } %>
        <% }); %>

        <%# Next %>
        <% if (currentPage < totalPages) { %>
          <a class="page-btn" href="/?page=<%= currentPage + 1 %>#latest" aria-label="الصفحة التالية">التالي ›</a>
        <% } else { %>
          <span class="page-btn disabled" aria-disabled="true">التالي ›</span>
        <% } %>
      </nav>
    <% } %>
  </section>
<% } %>

<h2 class="section-title" id="categories">تصفح الأقسام</h2>

<% if (categories.length === 0) { %>
  <div class="empty-state">
    <div class="icon">📦</div>
    <h3>لا توجد أقسام بعد</h3>
    <p>قم بإضافة الأقسام من لوحة التحكم</p>
  </div>
<% } else { %>
  <div class="categories-grid">
    <% categories.forEach(function(cat) { %>
      <a href="/category/<%= cat.slug %>" class="category-card">
        <% if (cat.image_type) { %>
          <img src="/cat-img/<%= cat.id %>" class="category-image" alt="<%= cat.name %>" loading="lazy" />
        <% } else { %>
          <div class="category-image-fallback">
            <span class="category-icon"><%= cat.icon || '🛍️' %></span>
          </div>
        <% } %>
        <div class="category-info">
          <div class="category-name"><%= cat.name %></div>
          <div class="category-count"><%= cat.product_count %> منتج</div>
        </div>
      </a>
    <% }); %>
  </div>
<% } %>

<%- include('partials/footer') %>