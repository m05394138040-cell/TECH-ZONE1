<%- include('partials/header') %>

<section class="hero">
  <img src="/img/logo.png?v=2" alt="<%= siteName %>" class="hero-logo" />
  <p>اكسسوارات الأجهزة الذكية — جميع المنتجات متوفرة بأسعار تنافسية</p>
</section>

<% if (settings.ticker_enabled === 'true' || !settings.ticker_enabled) { %>
  <% if (settings.ticker_text) { %>
    <div class="news-ticker" style="background: <%= settings.ticker_bg_color || '#0a0a0a' %>;">
      <div class="ticker-content" style="color: <%= settings.ticker_color || '#ffffff' %>;">
        <span class="ticker-text"><%= settings.ticker_text %></span>
      </div>
    </div>
  <% } %>
<% } %>

<% if (sliderImages && sliderImages.length > 0) { %>
  <section class="hero-slider" id="heroSlider" aria-label="سلايدر العروض">
    <div class="hero-slider-track" id="heroSliderTrack">
      <% sliderImages.forEach(function(img, i) { %>
        <% if (img.link_url) { %>
          <a class="hero-slider-slide" href="<%= img.link_url %>" data-index="<%= i %>" <%= img.link_url.startsWith('http') ? 'target="_blank" rel="noopener"' : '' %>>
        <% } else { %>
          <div class="hero-slider-slide" data-index="<%= i %>">
        <% } %>
          <img src="/slider-img/<%= img.id %>" alt="<%= img.title || ('عرض ' + (i + 1)) %>" loading="<%= i === 0 ? 'eager' : 'lazy' %>" />
          <% if (img.title) { %>
            <div class="hero-slider-caption"><%= img.title %></div>
          <% } %>
        <% if (img.link_url) { %>
          </a>
        <% } else { %>
          </div>
        <% } %>
      <% }); %>
    </div>

    <% if (sliderImages.length > 1) { %>
      <button class="hero-slider-arrow hero-slider-prev" id="heroSliderPrev" aria-label="السابق">‹</button>
      <button class="hero-slider-arrow hero-slider-next" id="heroSliderNext" aria-label="التالي">›</button>
      <div class="hero-slider-dots" id="heroSliderDots">
        <% sliderImages.forEach(function(_, i) { %>
          <button class="hero-slider-dot <%= i === 0 ? 'active' : '' %>" data-index="<%= i %>" aria-label="الانتقال للصورة <%= i + 1 %>"></button>
        <% }); %>
      </div>
    <% } %>
  </section>
<% } %>

<h2 class="section-title" id="categories">تصفح الأقسام</h2>

<% if (categories.length === 0) { %>
  <div class="empty-state">
    <div class="icon">📦</div>
    <h3>لا توجد أقسام بعد</h3>
    <p>قم بإضافة الأقسام من لوحة التحكم</p>
  </div>
<% } else { %>
  <div class="categories-grid">
    <% categories.forEach(function(cat) { %>
      <a href="/category/<%= cat.slug %>" class="category-card">
        <% if (cat.image_type) { %>
          <img src="/cat-img/<%= cat.id %>" class="category-image" alt="<%= cat.name %>" loading="lazy" />
        <% } else { %>
          <div class="category-image-fallback">
            <span class="category-icon"><%= cat.icon || '🛍️' %></span>
          </div>
        <% } %>
        <div class="category-info">
          <div class="category-name"><%= cat.name %></div>
          <div class="category-count"><%= cat.product_count %> منتج</div>
        </div>
      </a>
    <% }); %>
  </div>
<% } %>

<%- include('partials/footer') %>