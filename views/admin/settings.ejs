<%- include('_head') %>

<% if (error) { %><div class="error-msg"><%= error %></div><% } %>
<% if (success) { %><div class="success-msg"><%= success %></div><% } %>

<form method="POST" action="/admin/settings" enctype="multipart/form-data">

  <div class="form-section">
    <h2>📱 إعدادات الطلب عبر واتساب</h2>
    <div class="form-group">
      <label for="whatsapp_number">رقم الواتساب</label>
      <input type="text" id="whatsapp_number" name="whatsapp_number" value="<%= settings.whatsapp_number || '' %>" placeholder="+962790000000" dir="ltr" />
      <p style="color: var(--gray-muted); font-size: 12px; margin-top: 6px;">
        يُستخدم في زر "اطلب عبر واتساب". استخدم الصيغة الدولية: رمز الدولة + الرقم (بدون + أو 00 رح يتجاهلوا).
      </p>
    </div>
  </div>

  <div class="form-section">
    <h2>🏷️ اسم الموقع والشعار</h2>
    <div class="form-row cols-2">
      <div class="form-group">
        <label for="site_name">اسم الموقع</label>
        <input type="text" id="site_name" name="site_name" value="<%= settings.site_name || 'TECH ZONE' %>" />
      </div>
      <div class="form-group">
        <label for="logo_text">نص الشعار (إذا ما في صورة)</label>
        <input type="text" id="logo_text" name="logo_text" value="<%= settings.logo_text || settings.site_name || 'TECH ZONE' %>" />
      </div>
    </div>

    <div class="form-group">
      <label for="logo">شعار صورة (اختياري)</label>
      <% if (settings.logo_image) { %>
        <div style="margin-bottom: 12px;">
          <p style="color: var(--gray-text); font-size: 13px; margin-bottom: 8px;">الشعار الحالي:</p>
          <img src="/logo" style="max-width: 200px; max-height: 100px; border-radius: 8px; border: 1px solid var(--black-border); background: var(--black); padding: 8px;" alt="logo" />
          <label class="checkbox-row" style="margin-top: 12px;">
            <input type="checkbox" name="remove_logo" value="1" />
            <span style="color: #ff6b6b;">حذف الصورة والعودة للنص</span>
          </label>
        </div>
      <% } %>
      <input type="file" id="logo" name="logo" accept="image/*" />
      <p style="color: var(--gray-muted); font-size: 12px; margin-top: 6px;">PNG شفاف أفضل للشعارات — حد أقصى 5MB</p>
    </div>
  </div>

  <div class="form-section">
    <h2>🔗 روابط التواصل الاجتماعي</h2>
    <p style="color: var(--gray-text); font-size: 13px; margin-bottom: 14px;">
      حط روابط حساباتك الرسمية. اللي تخلّيه فاضي رح يختفي من الفوتر.
    </p>

    <div class="form-row cols-2">
      <div class="form-group">
        <label for="social_facebook">📘 فيسبوك</label>
        <input type="text" id="social_facebook" name="social_facebook" value="<%= settings.social_facebook || '' %>" placeholder="https://facebook.com/your-page" dir="ltr" />
      </div>
      <div class="form-group">
        <label for="social_instagram">📷 انستغرام</label>
        <input type="text" id="social_instagram" name="social_instagram" value="<%= settings.social_instagram || '' %>" placeholder="https://instagram.com/your-page" dir="ltr" />
      </div>
    </div>

    <div class="form-row cols-2">
      <div class="form-group">
        <label for="social_youtube">▶️ يوتيوب</label>
        <input type="text" id="social_youtube" name="social_youtube" value="<%= settings.social_youtube || '' %>" placeholder="https://youtube.com/@your-channel" dir="ltr" />
      </div>
      <div class="form-group">
        <label for="social_twitter">🐦 تويتر / X</label>
        <input type="text" id="social_twitter" name="social_twitter" value="<%= settings.social_twitter || '' %>" placeholder="https://x.com/your-handle" dir="ltr" />
      </div>
    </div>

    <div class="form-row cols-2">
      <div class="form-group">
        <label for="social_tiktok">🎵 تيك توك</label>
        <input type="text" id="social_tiktok" name="social_tiktok" value="<%= settings.social_tiktok || '' %>" placeholder="https://tiktok.com/@your-handle" dir="ltr" />
      </div>
      <div class="form-group">
        <label for="social_whatsapp">💬 واتساب (قناة/مجموعة)</label>
        <input type="text" id="social_whatsapp" name="social_whatsapp" value="<%= settings.social_whatsapp || '' %>" placeholder="https://whatsapp.com/channel/..." dir="ltr" />
      </div>
    </div>
  </div>

  <div class="form-section">
    <h2>💱 إعدادات العملات (الجملة / التجزئة)</h2>
    <p style="color: var(--gray-text); font-size: 13px; margin-bottom: 14px;">
      السعر في المنتجات مخزّن بالدولار (USD). الزوار يشوفونه محوّل للّيرة التركية، تجار الجملة (بعد تسجيل دخول) يشوفونه بالدولار.
    </p>

    <div class="form-row cols-2">
      <div class="form-group">
        <label for="wholesale_currency">رمز عملة الجملة</label>
        <input type="text" id="wholesale_currency" name="wholesale_currency" value="<%= settings.wholesale_currency || 'USD' %>" maxlength="5" dir="ltr" />
      </div>
      <div class="form-group">
        <label for="wholesale_symbol">رمز الجملة ($/₺/€)</label>
        <input type="text" id="wholesale_symbol" name="wholesale_symbol" value="<%= settings.wholesale_symbol || '$' %>" maxlength="3" dir="ltr" />
      </div>
    </div>

    <div class="form-row cols-2">
      <div class="form-group">
        <label for="retail_currency">رمز عملة الزوار</label>
        <input type="text" id="retail_currency" name="retail_currency" value="<%= settings.retail_currency || 'TRY' %>" maxlength="5" dir="ltr" />
      </div>
      <div class="form-group">
        <label for="retail_symbol">رمز الزوار</label>
        <input type="text" id="retail_symbol" name="retail_symbol" value="<%= settings.retail_symbol || '₺' %>" maxlength="3" dir="ltr" />
      </div>
    </div>

    <div class="form-group">
      <label for="exchange_rate">سعر الصرف (1 USD = ؟)</label>
      <input type="number" id="exchange_rate" name="exchange_rate" value="<%= settings.exchange_rate || '32' %>" step="0.01" min="0.01" dir="ltr" style="max-width: 200px;" />
      <p style="color: var(--gray-muted); font-size: 12px; margin-top: 6px;">
        عدّل هاد الرقم حسب سعر الصرف الحالي. مثال: 1 USD = 32 ₺
      </p>
    </div>
  </div>

  <div class="form-section">
    <h2>📰 الشريط الإخباري</h2>
    <p style="color: var(--gray-text); font-size: 13px; margin-bottom: 14px;">
      شريط نصي متحرك يظهر بين الـ hero وقسم الأقسام. ممكن تفعّله، توقّفه، تغيّر النص أو اللون.
    </p>

    <div class="form-group">
      <label class="checkbox-row" style="display: inline-flex; width: auto; padding: 8px 16px;">
        <input type="checkbox" name="ticker_enabled" <%= settings.ticker_enabled === 'true' || !settings.ticker_enabled ? 'checked' : '' %> />
        <span>إظهار الشريط الإخباري</span>
      </label>
    </div>

    <div class="form-group">
      <label for="ticker_text">النص (استخدم • أو | للفصل بين الرسائل)</label>
      <textarea id="ticker_text" name="ticker_text" rows="3" placeholder="مثال: عروض حصرية على السماعات • شحن مجاني للطلبات فوق 50$ • ضمان سنة كاملة"><%= settings.ticker_text || '' %></textarea>
    </div>

    <div class="form-row cols-2">
      <div class="form-group">
        <label for="ticker_color">لون النص</label>
        <div style="display: flex; gap: 8px; align-items: center;">
          <input type="color" id="ticker_color" name="ticker_color" value="<%= settings.ticker_color || '#ffffff' %>" style="width: 60px; height: 40px; padding: 2px; cursor: pointer;" />
          <input type="text" value="<%= settings.ticker_color || '#ffffff' %>" readonly style="flex: 1; font-family: monospace;" id="ticker_color_text" />
        </div>
      </div>
      <div class="form-group">
        <label for="ticker_bg_color">لون الخلفية</label>
        <div style="display: flex; gap: 8px; align-items: center;">
          <input type="color" id="ticker_bg_color" name="ticker_bg_color" value="<%= settings.ticker_bg_color || '#0a0a0a' %>" style="width: 60px; height: 40px; padding: 2px; cursor: pointer;" />
          <input type="text" value="<%= settings.ticker_bg_color || '#0a0a0a' %>" readonly style="flex: 1; font-family: monospace;" id="ticker_bg_color_text" />
        </div>
      </div>
    </div>
  </div>

  <div style="display: flex; gap: 12px;">
    <button type="submit" class="btn btn-primary">💾 حفظ الإعدادات</button>
  </div>
</form>

<div class="form-section" style="margin-top: 24px;">
  <h2>🔒 معلومات الحساب</h2>
  <p style="color: var(--gray-text); line-height: 1.8; font-size: 14px;">
    لتغيير اسم المستخدم أو كلمة المرور، تواصل مع المطوّر. (هاد الإصدار ما يدعم تغيير بيانات الدخول من اللوحة.)
  </p>
</div>

<%- include('_foot') %>