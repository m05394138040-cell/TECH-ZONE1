<%- include('_head') %>

<% if (error) { %><div class="error-msg"><%= error %></div><% } %>

<form method="POST" action="<%= product ? '/admin/products/' + product.id + '/edit' : '/admin/products/new' %>" enctype="multipart/form-data">
  <div class="form-section">
    <h2>📦 معلومات المنتج</h2>

    <div class="form-row cols-2">
      <div class="form-group">
        <label for="name">اسم المنتج *</label>
        <input type="text" id="name" name="name" required value="<%= product ? product.name : '' %>" placeholder="مثال: سماعات بلوتوث برو" />
      </div>
      <div class="form-group">
        <label for="category_id">القسم *</label>
        <select id="category_id" name="category_id" required>
          <option value="">— اختر القسم —</option>
          <% categories.forEach(function(cat) { %>
            <option value="<%= cat.id %>" <%= product && product.category_id === cat.id ? 'selected' : '' %>><%= cat.icon %> <%= cat.name %></option>
          <% }); %>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label for="description">الوصف</label>
      <textarea id="description" name="description" rows="3" placeholder="وصف مختصر للمنتج (اختياري)"><%= product ? product.description : '' %></textarea>
    </div>

    <div class="form-row cols-2">
      <div class="form-group">
        <label for="price">💵 سعر الجملة (USD) *</label>
        <input type="number" id="price" name="price" step="0.01" min="0" required value="<%= product ? product.price : '' %>" placeholder="0.00" dir="ltr" />
        <p style="color: var(--gray-muted); font-size: 12px; margin-top: 4px;">السعر اللي بيشوفوه صاحب المحل بعد تسجيل الدخول</p>
      </div>
      <div class="form-group">
        <label for="price_retail">💰 سعر الزوار (ل.ت) *</label>
        <input type="number" id="price_retail" name="price_retail" step="0.01" min="0" required value="<%= product ? (product.price_retail || '') : '' %>" placeholder="0.00" dir="ltr" />
        <p style="color: var(--gray-muted); font-size: 12px; margin-top: 4px;">السعر اللي بيشوفوه الزوار بدون تسجيل دخول</p>
      </div>
      <div class="form-group">
        <label>الحالة</label>
        <label class="checkbox-row">
          <input type="checkbox" name="available" <%= !product || product.available ? 'checked' : '' %> />
          <span>المنتج متوفر للطلب</span>
        </label>
      </div>
    </div>
  </div>

  <div class="form-section" style="background: linear-gradient(135deg, rgba(212, 175, 55, 0.06), rgba(212, 175, 55, 0.02)); border: 1px dashed rgba(212, 175, 55, 0.5); border-radius: 14px; padding: 18px 20px;">
    <h2 style="color: var(--gold-dark);">🔒 معلومات خاصة بالأدمن (مخفية عن الجميع)</h2>
    <p style="color: var(--gray-text); font-size: 13px; margin-bottom: 14px;">
      المعلومات التالية <strong>ما بتظهر أبداً</strong> للزوار أو أصحاب المحلات. بتظهر فقط في لوحة التحكم عشان تعرف تكاليفك وأرباحك.
    </p>

    <div class="form-row cols-2">
      <div class="form-group">
        <label for="price_cost">💸 سعر الشراء (التكلفة) USD</label>
        <input type="number" id="price_cost" name="price_cost" step="0.01" min="0" value="<%= product ? (product.price_cost || '') : '' %>" placeholder="0.00" dir="ltr" />
        <p style="color: var(--gray-muted); font-size: 12px; margin-top: 4px;">السعر اللي اشتريت فيه المنتج — لأغراضك فقط</p>
      </div>
      <div class="form-group">
        <label>📊 هامش الربح المتوقع</label>
        <div id="profit-preview" style="padding: 10px 14px; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border); border-radius: 8px; font-size: 14px; color: var(--text); min-height: 24px;">
          <span style="color: var(--gray-muted);">سيتم الحساب تلقائياً</span>
        </div>
        <p style="color: var(--gray-muted); font-size: 12px; margin-top: 4px;">يحسب الفرق بين سعر الجملة وسعر الشراء</p>
      </div>
    </div>
  </div>

  <div class="form-section">
    <h2>🖼️ صورة المنتج</h2>

    <% if (product && product.image_type) { %>
      <div style="margin-bottom: 14px;">
        <p style="color: var(--gray-text); font-size: 13px; margin-bottom: 8px;">الصورة الحالية:</p>
        <img src="/img/<%= product.id %>" style="max-width: 200px; max-height: 200px; border-radius: 8px; border: 1px solid var(--black-border);" alt="current" />
        <label class="checkbox-row" style="margin-top: 12px;">
          <input type="checkbox" name="remove_image" value="1" />
          <span style="color: #ff6b6b;">حذف الصورة الحالية</span>
        </label>
      </div>
    <% } %>

    <div class="form-group">
      <label for="image"><%= product && product.image_type ? 'استبدال الصورة (اختياري)' : 'رفع صورة' %></label>
      <input type="file" id="image" name="image" accept="image/*" />
      <p style="color: var(--gray-muted); font-size: 12px; margin-top: 6px;">JPG, PNG, GIF, WEBP — حد أقصى 5MB</p>
    </div>
  </div>

  <div style="display: flex; gap: 12px; flex-wrap: wrap;">
    <button type="submit" class="btn btn-primary">💾 حفظ المنتج</button>
    <a href="/admin/products" class="btn btn-secondary">إلغاء</a>
  </div>
</form>

<script>
  // Live profit margin calculation
  (function () {
    const priceInput = document.getElementById('price');
    const costInput = document.getElementById('price_cost');
    const preview = document.getElementById('profit-preview');
    if (!priceInput || !costInput || !preview) return;

    function updateProfit() {
      const price = parseFloat(priceInput.value) || 0;
      const cost = parseFloat(costInput.value) || 0;
      if (cost <= 0) {
        preview.innerHTML = '<span style="color: var(--gray-muted);">أدخل سعر الشراء لحساب الربح</span>';
        return;
      }
      if (price <= 0) {
        preview.innerHTML = '<span style="color: var(--gray-muted);">أدخل سعر الجملة أولاً</span>';
        return;
      }
      const profit = price - cost;
      const margin = price > 0 ? ((profit / price) * 100).toFixed(1) : 0;
      const costMultiplier = cost > 0 ? (price / cost).toFixed(2) : 0;
      const color = profit > 0 ? '#22c55e' : (profit < 0 ? '#ef4444' : 'var(--text)');
      const arrow = profit > 0 ? '📈' : (profit < 0 ? '📉' : '➖');
      preview.innerHTML =
        '<div style="display:flex; flex-direction:column; gap:4px;">' +
          '<div style="font-size:18px; font-weight:800; color:' + color + ';">' +
            arrow + ' ' + profit.toFixed(2) + ' $ ربح / قطعة' +
          '</div>' +
          '<div style="font-size:12px; color: var(--gray-muted);">' +
            'هامش ' + margin + '% • ' + costMultiplier + '× التكلفة' +
          '</div>' +
        '</div>';
    }

    priceInput.addEventListener('input', updateProfit);
    costInput.addEventListener('input', updateProfit);
    updateProfit();
  })();
</script>

<%- include('_foot') %>