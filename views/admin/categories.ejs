<%- include('_head') %>

<% if (error) { %><div class="error-msg"><%= error %></div><% } %>
<% if (success) { %><div class="success-msg"><%= success %></div><% } %>

<div class="form-section">
  <h2>➕ إضافة قسم جديد</h2>
  <form method="POST" action="/admin/categories">
    <div class="form-row cols-2">
      <div class="form-group">
        <label for="name">اسم القسم</label>
        <input type="text" id="name" name="name" required placeholder="مثال: السماعات" />
      </div>
      <div class="form-group">
        <label for="icon">الأيقونة (إيموجي)</label>
        <input type="text" id="icon" name="icon" placeholder="🎧" maxlength="4" />
      </div>
    </div>
    <button type="submit" class="btn btn-primary">إضافة القسم</button>
  </form>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th style="width: 60px;">الترتيب</th>
        <th style="width: 60px;">الأيقونة</th>
        <th>اسم القسم</th>
        <th>المعرف (slug)</th>
        <th style="width: 100px;">المنتجات</th>
        <th style="width: 240px;">إجراءات</th>
      </tr>
    </thead>
    <tbody>
      <% if (categories.length === 0) { %>
        <tr><td colspan="6" style="text-align: center; color: var(--gray-muted); padding: 40px;">لا توجد أقسام بعد</td></tr>
      <% } %>
      <% categories.forEach(function(cat) { %>
        <tr>
          <td><%= cat.sort_order %></td>
          <td style="font-size: 24px;"><%= cat.icon || '🛍️' %></td>
          <td><strong style="color: var(--white);"><%= cat.name %></strong></td>
          <td><code style="background: var(--black); padding: 2px 8px; border-radius: 4px; font-size: 12px; color: var(--gray-text);"><%= cat.slug %></code></td>
          <td><span style="color: var(--gold); font-weight: 700;"><%= cat.product_count %></span></td>
          <td class="actions">
            <form method="POST" action="/admin/categories/<%= cat.id %>/update" style="display: inline-flex; gap: 4px; flex: 1;">
              <input type="text" name="name" value="<%= cat.name %>" required style="flex: 1; min-width: 0; padding: 6px 8px; font-size: 13px;" />
              <input type="text" name="icon" value="<%= cat.icon || '' %>" maxlength="4" style="width: 50px; padding: 6px 8px; font-size: 13px;" />
              <button type="submit" class="btn btn-secondary btn-sm">💾</button>
            </form>
            <form method="POST" action="/admin/categories/<%= cat.id %>/delete" style="display: inline;" data-confirm="حذف القسم وكل المنتجات داخله؟">
              <button type="submit" class="btn btn-danger btn-sm">🗑️</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('_foot') %>