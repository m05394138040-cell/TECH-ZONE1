<%- include('_head') %>

<% if (error) { %><div class="error-msg"><%= error %></div><% } %>
<% if (success) { %><div class="success-msg"><%= success %></div><% } %>
<% if (typeof query !== 'undefined' && query && query.logged_out) { %><div class="success-msg">✅ تم تسجيل خروج البوت ومسح بيانات الجلسة</div><% } %>

<div class="form-section">
  <h2>🤖 بوت WhatsApp - TECH ZONE</h2>
  <p style="color: var(--gray-text); font-size: 13px; margin-bottom: 14px;">
    هذا البوت يرسل إشعارات تلقائية (قبول/رفض طلبات الجملة) على واتساب. شغّله مرة واحدة وامسح QR Code من هاتفك المرتبط بواتساب.
  </p>

  <%
    const statusInfo = {
      disconnected: { color: '#ef4444', icon: '🔴', label: 'غير متصل' },
      initializing: { color: '#fbbf24', icon: '⏳', label: 'جاري التهيئة...' },
      qr: { color: '#fbbf24', icon: '📱', label: 'بانتظار مسح QR Code' },
      authenticated: { color: '#3b82f6', icon: '🔄', label: 'جاري المصادقة...' },
      ready: { color: '#22c55e', icon: '✅', label: 'متصل وجاهز للإرسال' },
      auth_failure: { color: '#ef4444', icon: '❌', label: 'فشل المصادقة' },
    };
    const info = statusInfo[status.status] || statusInfo.disconnected;
  %>

  <div style="background: var(--dark-card); border: 2px solid <%= info.color %>; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
    <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 12px;">
      <div style="font-size: 36px;"><%= info.icon %></div>
      <div style="flex: 1;">
        <div style="font-size: 22px; font-weight: 800; color: <%= info.color %>;"><%= info.label %></div>
        <% if (status.phoneNumber) { %>
          <div style="color: var(--gray-text); font-size: 13px; margin-top: 4px;">
            📱 الرقم: <span dir="ltr" style="color: var(--gold); font-weight: 700;">+<%= status.phoneNumber %></span>
            <% if (status.pushName) { %> • 👤 <%= status.pushName %><% } %>
          </div>
        <% } %>
        <% if (status.lastError) { %>
          <div style="color: #fca5a5; font-size: 12px; margin-top: 4px;">⚠️ <%= status.lastError %></div>
        <% } %>
      </div>
    </div>

    <% if (status.status === 'qr' && status.qr) { %>
      <div style="text-align: center; margin: 20px 0;">
        <div style="background: #fff; padding: 16px; display: inline-block; border-radius: 12px;">
          <img src="<%= status.qr %>" alt="QR Code" style="display: block; max-width: 320px; width: 100%;" />
        </div>
        <p style="color: var(--gold); font-weight: 700; margin-top: 14px;">
          📱 امسح هذا الـ QR من تطبيق WhatsApp على هاتفك
        </p>
        <p style="color: var(--gray-text); font-size: 12px; margin-top: 6px;">
          (الإعدادات → الأجهزة المرتبطة → ربط جهاز)<br>
          <strong style="color: var(--white);">نصيحة:</strong> غيّر اسم حسابك في واتساب إلى "TECH ZONE" قبل المسح عشان يظهر كمرسل رسمي.
        </p>
      </div>
    <% } %>

    <% if (status.status === 'ready') { %>
      <div style="display: flex; gap: 8px; margin-top: 14px; flex-wrap: wrap;">
        <form method="POST" action="/admin/bot/logout" style="display: inline;">
          <button type="submit" class="btn btn-danger btn-sm" data-confirm="هل تريد تسجيل خروج البوت؟ سيتعين عليك مسح QR جديد.">
            🔌 تسجيل خروج
          </button>
        </form>
        <span style="color: var(--gray-muted); font-size: 12px; align-self: center;">
          آخر نشاط: <%= status.lastActivity ? new Date(status.lastActivity).toLocaleString('ar-EG') : 'لا يوجد' %>
        </span>
      </div>
    <% } %>
  </div>

  <% if (status.status === 'ready') { %>
  <div class="form-section" style="background: rgba(34, 197, 94, 0.05);">
    <h3>🧪 اختبار البوت</h3>
    <p style="color: var(--gray-text); font-size: 13px; margin-bottom: 14px;">
      أرسل رسالة تجريبية للتأكد أن البوت شغّال
    </p>
    <form method="POST" action="/admin/bot/test">
      <div class="form-group">
        <label for="test-phone">رقم الجوال (مع كود الدولة)</label>
        <input type="tel" id="test-phone" name="phone" placeholder="+90 555 123 4567" dir="ltr" required />
      </div>
      <div class="form-group">
        <label for="test-message">نص الرسالة</label>
        <textarea id="test-message" name="message" rows="3" required>مرحباً! هذه رسالة تجريبية من TECH ZONE. ✅</textarea>
      </div>
      <button type="submit" class="btn btn-primary">📤 إرسال رسالة تجريبية</button>
    </form>
  </div>
  <% } %>

  <div class="form-section">
    <h3>📜 سجل آخر الرسائل</h3>
    <% if (!status.messageLog || status.messageLog.length === 0) { %>
      <div style="text-align: center; padding: 30px; color: var(--gray-muted);">
        <div style="font-size: 36px; margin-bottom: 8px;">📭</div>
        لا توجد رسائل بعد
      </div>
    <% } else { %>
      <div style="display: flex; flex-direction: column; gap: 8px; max-height: 400px; overflow-y: auto;">
        <% status.messageLog.forEach(function(m) { %>
          <div style="background: var(--dark-card); border: 1px solid var(--black-border); border-radius: 8px; padding: 10px 14px; display: flex; align-items: flex-start; gap: 10px;">
            <% if (m.direction === 'sent') { %>
              <span style="color: #22c55e; font-size: 18px;">📤</span>
            <% } else if (m.direction === 'system') { %>
              <span style="color: #3b82f6; font-size: 18px;">⚙️</span>
            <% } else { %>
              <span style="color: #fbbf24; font-size: 18px;">📥</span>
            <% } %>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 12px; color: var(--gray-muted);">
                <%= m.direction === 'sent' ? 'مرسلة' : (m.direction === 'system' ? 'نظام' : 'مستقبلة') %>
                <% if (m.phone) { %> • <span dir="ltr">+<%= m.phone %></span><% } %>
                • <%= new Date(m.time).toLocaleString('ar-EG', { hour: '2-digit', minute: '2-digit', second: '2-digit', day: '2-digit', month: '2-digit' }) %>
              </div>
              <div style="color: var(--white); font-size: 13px; margin-top: 3px; word-wrap: break-word; white-space: pre-wrap;">
                <%= m.message %>
              </div>
              <% if (m.status === 'fail') { %>
                <div style="color: #fca5a5; font-size: 11px; margin-top: 2px;">❌ فشل الإرسال</div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <div class="form-section" style="background: rgba(255, 165, 0, 0.05); border-color: orange;">
    <h3>⚠️ معلومات مهمة</h3>
    <ul style="color: var(--gray-text); font-size: 13px; line-height: 1.8; padding-right: 20px;">
      <li>البوت يستخدم <strong>WhatsApp Web API</strong> (غير رسمي). للاستخدام التجاري الكبير، يُفضل استخدام WhatsApp Business API الرسمي.</li>
      <li>على <strong>Render Free tier</strong>، البوت ينقطع بعد 15 دقيقة بدون نشاط. للاستمرار 24/7، اشترك في <strong>Render Starter</strong> ($7/شهر).</li>
      <li>الجلسة محفوظة في <code>/tmp/wwebjs_auth</code> على Render. عند كل نشر (deploy) جديد، قد تحتاج لمسح QR من جديد.</li>
      <li><strong>نصيحة:</strong> غيّر اسم حسابك في واتساب إلى "TECH ZONE" قبل المسح عشان يظهر كمرسل رسمي.</li>
    </ul>
  </div>
</div>

<script>
  // Auto-refresh the page every 10s to update QR / status
  setTimeout(() => location.reload(), 10000);
</script>

<%- include('_foot') %>
