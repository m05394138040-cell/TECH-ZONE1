<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 100" width="260" height="65">
  <defs>
    <!-- Gold gradient for the T-keyboard -->
    <linearGradient id="goldT" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#f4d03f"/>
      <stop offset="50%" style="stop-color:#d4af37"/>
      <stop offset="100%" style="stop-color:#b8860b"/>
    </linearGradient>
    <linearGradient id="goldGlow" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#d4af37;stop-opacity:0.3"/>
      <stop offset="50%" style="stop-color:#f4d03f;stop-opacity:0.6"/>
      <stop offset="100%" style="stop-color:#d4af37;stop-opacity:0.3"/>
    </linearGradient>
  </defs>

  <!-- Keyboard-T shape (stylized) -->
  <g transform="translate(10, 12)">
    <!-- T vertical -->
    <rect x="22" y="20" width="14" height="50" rx="2" fill="url(#goldT)" stroke="#b8860b" stroke-width="0.8"/>
    <!-- T horizontal top -->
    <rect x="2" y="4" width="54" height="18" rx="2" fill="url(#goldT)" stroke="#b8860b" stroke-width="0.8"/>
    <!-- Key details (small rects to look like keys) -->
    <rect x="5" y="7" width="6" height="12" rx="1" fill="#fdfaf3" opacity="0.4"/>
    <rect x="13" y="7" width="6" height="12" rx="1" fill="#fdfaf3" opacity="0.4"/>
    <rect x="21" y="7" width="6" height="12" rx="1" fill="#fdfaf3" opacity="0.4"/>
    <rect x="29" y="7" width="6" height="12" rx="1" fill="#fdfaf3" opacity="0.4"/>
    <rect x="37" y="7" width="6" height="12" rx="1" fill="#fdfaf3" opacity="0.4"/>
    <rect x="45" y="7" width="6" height="12" rx="1" fill="#fdfaf3" opacity="0.4"/>
    <rect x="25" y="24" width="8" height="6" rx="1" fill="#fdfaf3" opacity="0.4"/>
    <rect x="25" y="32" width="8" height="6" rx="1" fill="#fdfaf3" opacity="0.4"/>
    <rect x="25" y="40" width="8" height="6" rx="1" fill="#fdfaf3" opacity="0.4"/>
    <rect x="25" y="48" width="8" height="6" rx="1" fill="#fdfaf3" opacity="0.4"/>
    <!-- USB cable coming out of T -->
    <path d="M 50 22 Q 65 22 70 35 Q 75 48 80 50" stroke="url(#goldT)" stroke-width="2" fill="none" stroke-linecap="round"/>
    <rect x="76" y="48" width="8" height="4" rx="0.5" fill="#d4af37" stroke="#b8860b" stroke-width="0.5"/>
  </g>

  <!-- TECH text (dark navy/black) -->
  <text x="105" y="48" font-family="Arial Black, Arial, sans-serif" font-size="32" font-weight="900" fill="#1a1a2e" letter-spacing="2">TECH</text>

  <!-- ZONE text (gold with glow) -->
  <text x="200" y="48" font-family="Arial Black, Arial, sans-serif" font-size="32" font-weight="900" fill="url(#goldGlow)" stroke="#d4af37" stroke-width="0.8" letter-spacing="2">ZONE</text>

  <!-- Decorative line + tagline -->
  <line x1="105" y1="62" x2="128" y2="62" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round"/>
  <text x="134" y="66" font-family="Arial, sans-serif" font-size="8" font-weight="600" fill="#1a1a1a" letter-spacing="1.8">MOBILE &amp; COMPUTER ACCESSORIES</text>
  <line x1="368" y1="62" x2="388" y2="62" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round"/>

  <!-- Small decorative dots under tagline -->
  <circle cx="240" cy="82" r="2" fill="#d4af37"/>
  <circle cx="248" cy="82" r="2" fill="#d4af37" opacity="0.6"/>
  <circle cx="256" cy="82" r="2" fill="#d4af37" opacity="0.3"/>
</svg>
