<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#fdfaf3" />
  <meta name="description" content="<%= siteName %> — متجر إلكتروني متخصص في اكسسوارات الأجهزة الذكية" />
  <title><%= title %> | <%= siteName %></title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%23fdfaf3'/%3E%3Cpath d='M32 8 L52 16 L52 32 Q52 48 32 56 Q12 48 12 32 L12 16 Z' fill='%23d4af37' stroke='%23b8860b' stroke-width='2'/%3E%3Ctext x='32' y='40' font-family='Arial' font-size='24' font-weight='900' fill='%23fdfaf3' text-anchor='middle'%3ET%3C/text%3E%3C/svg%3E" />
</head>
<body>
<div class="page">
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <img src="/img/logo-header.png?v=2" alt="<%= siteName %>" class="header-logo-img" />
      </a>
      <div class="header-search" id="headerSearch">
        <form class="header-search-form" action="/search" method="get" role="search">
          <svg class="header-search-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M21 21l-4.35-4.35M11 18a7 7 0 1 1 0-14 7 7 0 0 1 0 14z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <input type="search" name="q" id="globalSearchInput" placeholder="ابحث عن منتج (مثلاً A20)..." autocomplete="off" aria-label="بحث عن منتج" />
          <button type="button" class="header-search-clear" id="searchClear" aria-label="مسح" hidden>×</button>
        </form>
        <div class="header-search-dropdown" id="searchDropdown" hidden>
          <div class="search-dropdown-empty" id="searchDropdownEmpty" hidden>لا توجد نتائج</div>
          <div class="search-dropdown-results" id="searchDropdownResults"></div>
          <a class="search-dropdown-all" id="searchDropdownAll" href="/search?q=" hidden>
            عرض كل النتائج ←
          </a>
        </div>
      </div>
      <nav class="header-nav">
        <a href="/" class="nav-link">الرئيسية</a>
        <a href="/#categories" class="nav-link">الأقسام</a>
        <% if (isWholesale) { %>
          <a href="/wholesale-logout" class="nav-link wholesale-badge" title="تسجيل خروج">🏪 <%= wholesaleUsername %> ✕</a>
        <% } else { %>
          <a href="/wholesale-login" class="nav-link">🔐 تسجيل الدخول</a>
        <% } %>
        <div class="nav-contact-wrapper">
          <button type="button" class="nav-link nav-contact-btn" id="contactToggle" aria-haspopup="true" aria-expanded="false">
            تواصل <span class="caret">▾</span>
          </button>
          <div class="contact-dropdown" id="contactDropdown" role="menu">
            <% if (settings.social_facebook) { %>
              <a href="<%= settings.social_facebook %>" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z" fill="#1877F2"/></svg>
                <span>فيسبوك</span>
              </a>
            <% } %>
            <% if (settings.social_instagram) { %>
              <a href="<%= settings.social_instagram %>" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="ig" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" style="stop-color:#FD5949"/><stop offset="50%" style="stop-color:#D6249F"/><stop offset="100%" style="stop-color:#285AEB"/></linearGradient></defs><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.72 3.72 0 0 1-1.38-.9 3.72 3.72 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.86 5.86 0 0 0-2.13 1.38A5.86 5.86 0 0 0 .63 4.14C.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91a5.86 5.86 0 0 0 1.38 2.13 5.86 5.86 0 0 0 2.13 1.38c.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.86 5.86 0 0 0 2.13-1.38 5.86 5.86 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.86 5.86 0 0 0-1.38-2.13A5.86 5.86 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z" fill="url(#ig)"/></svg>
                <span>انستغرام</span>
              </a>
            <% } %>
            <% if (settings.social_youtube) { %>
              <a href="<%= settings.social_youtube %>" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M21.582 6.186a2.506 2.506 0 0 0-1.768-1.768C18.254 4 12 4 12 4s-6.254 0-7.814.418a2.506 2.506 0 0 0-1.768 1.768C2 7.746 2 12 2 12s0 4.254.418 5.814a2.506 2.506 0 0 0 1.768 1.768C5.746 20 12 20 12 20s6.254 0 7.814-.418a2.506 2.506 0 0 0 1.768-1.768C22 16.254 22 12 22 12s0-4.254-.418-5.814zM10 15.464V8.536L16 12l-6 3.464z" fill="#FF0000"/></svg>
                <span>يوتيوب</span>
              </a>
            <% } %>
            <% if (settings.social_twitter) { %>
              <a href="<%= settings.social_twitter %>" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="#000"/></svg>
                <span>X / تويتر</span>
              </a>
            <% } %>
            <% if (settings.social_tiktok) { %>
              <a href="<%= settings.social_tiktok %>" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.51a8.16 8.16 0 0 0 4.77 1.52V6.69a4.85 4.85 0 0 1-1.84 0z" fill="#000"/></svg>
                <span>تيك توك</span>
              </a>
            <% } %>
            <% if (settings.social_whatsapp) { %>
              <a href="<%= settings.social_whatsapp %>" target="_blank" rel="noopener noreferrer" role="menuitem">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074 1.488 2.095 2.896 3.122 4.647 4.092.539.307.96.491 1.291.629.517.232.988.199 1.361.12.416-.09 1.288-.527 1.47-1.035.182-.508.182-.944.127-1.035-.055-.091-.199-.149-.371-.249m.812-9.713c-4.142 0-7.494 3.353-7.494 7.495 0 1.388.363 2.717 1.027 3.84l-1.092 3.286 3.358-1.084a7.434 7.434 0 0 0 3.567.91h.004c4.142 0 7.494-3.353 7.494-7.495 0-2.003-.778-3.886-2.193-5.302a7.452 7.452 0 0 0-5.303-2.193h-.368" fill="#25D366"/></svg>
                <span>واتساب</span>
              </a>
            <% } %>
            <% if (!settings.social_facebook && !settings.social_instagram && !settings.social_youtube && !settings.social_twitter && !settings.social_tiktok && !settings.social_whatsapp) { %>
              <div class="dropdown-empty">لا توجد روابط بعد</div>
            <% } %>
          </div>
        </div>
      </nav>
      <div class="header-actions">
        <% if (isAdmin) { %>
          <a href="/admin" class="header-link">⚙ لوحة التحكم</a>
        <% } %>
      </div>
    </div>
  </header>
  <main>
    <div class="container">