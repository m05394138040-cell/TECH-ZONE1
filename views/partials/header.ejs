<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#fdfaf3" />
  <meta name="description" content="<%= siteName %> — متجر إلكتروني متخصص في اكسسوارات الأجهزة الذكية" />
  <title><%= title %> | <%= siteName %></title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%23fdfaf3'/%3E%3Cpath d='M32 8 L52 16 L52 32 Q52 48 32 56 Q12 48 12 32 L12 16 Z' fill='%23d4af37' stroke='%23b8860b' stroke-width='2'/%3E%3Ctext x='32' y='40' font-family='Arial' font-size='24' font-weight='900' fill='%23fdfaf3' text-anchor='middle'%3ET%3C/text%3E%3C/svg%3E" />
</head>
<body>
<div class="page">
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <% if (settings.logo_image) { %>
          <img src="/logo" alt="<%= siteName %>" class="header-logo-img" style="width:38px; height:38px; border-radius:8px;" />
        <% } else { %>
          <svg class="logo-shield" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="shieldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#f4d03f;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#b8860b;stop-opacity:1" />
              </linearGradient>
            </defs>
            <path d="M32 4 L56 14 L56 34 Q56 50 32 60 Q8 50 8 34 L8 14 Z" fill="url(#shieldGrad)" stroke="#b8860b" stroke-width="1.5" />
            <text x="32" y="40" font-family="Arial" font-size="26" font-weight="900" fill="#fdfaf3" text-anchor="middle">T</text>
          </svg>
        <% } %>
        <div class="logo-text-wrap">
          <div class="logo-text"><%= settings.logo_text || siteName %></div>
          <div class="logo-tagline">ACCESSORIES STORE</div>
        </div>
      </a>
      <div class="header-actions">
        <% if (isAdmin) { %>
          <a href="/admin" class="header-link">⚙ لوحة التحكم</a>
        <% } %>
      </div>
    </div>
  </header>
  <main>
    <div class="container">