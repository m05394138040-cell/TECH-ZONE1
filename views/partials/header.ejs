<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#0a0a0a" />
  <meta name="description" content="<%= siteName %> — متجر إلكتروني متخصص في اكسسوارات الأجهزة الذكية" />
  <title><%= title %> | <%= siteName %></title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%230a0a0a'/%3E%3Ctext x='32' y='42' font-family='Arial' font-size='32' font-weight='900' fill='%23d4af37' text-anchor='middle'%3ET%3C/text%3E%3C/svg%3E" />
</head>
<body>
<div class="page">
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <% if (settings.logo_image) { %>
          <img src="/logo" alt="<%= siteName %>" class="header-logo-img" />
        <% } %>
        <div>
          <div class="logo-text"><%= settings.logo_text || siteName %></div>
          <div class="logo-tagline">ACCESSORIES STORE</div>
        </div>
      </a>
      <div class="header-actions">
        <% if (isAdmin) { %>
          <a href="/admin" class="header-link">⚙ لوحة التحكم</a>
        <% } %>
      </div>
    </div>
  </header>
  <main>
    <div class="container">