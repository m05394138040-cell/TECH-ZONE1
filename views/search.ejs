<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <%- include('partials/head', { title: title }) %>
  <style>
    .search-hero {
      max-width: 720px;
      margin: 16px auto 24px;
      padding: 0 16px;
      text-align: center;
    }
    .search-hero h1 {
      font-size: 26px;
      color: var(--text);
      margin-bottom: 8px;
    }
    .search-hero .query {
      color: var(--gold-dark);
      font-weight: 800;
    }
    .search-hero .count {
      color: var(--text-muted);
      font-size: 15px;
      margin-top: 6px;
    }
    .search-form {
      display: flex;
      gap: 8px;
      max-width: 720px;
      margin: 16px auto 0;
      padding: 0 16px;
    }
    .search-form input {
      flex: 1;
      padding: 14px 18px;
      border: 2px solid var(--border);
      border-radius: 12px;
      font-family: inherit;
      font-size: 16px;
      background: #fff;
      color: var(--text);
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .search-form input:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
    }
    .search-form button {
      padding: 0 22px;
      background: linear-gradient(135deg, var(--gold), var(--gold-dark));
      color: #fff;
      border: none;
      border-radius: 12px;
      font-weight: 800;
      font-size: 15px;
      cursor: pointer;
      transition: transform 0.1s, box-shadow 0.15s;
      box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);
    }
    .search-form button:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(212, 175, 55, 0.4);
    }
    .search-results {
      max-width: 1100px;
      margin: 24px auto;
      padding: 0 16px;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 18px;
    }
    .result-card {
      background: #fff;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
      border: 1px solid var(--border);
      transition: transform 0.15s, box-shadow 0.15s;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
    }
    .result-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    }
    .result-image {
      width: 100%;
      aspect-ratio: 1 / 1;
      background: #fafafa;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .result-image img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
    }
    .result-image .no-image {
      font-size: 64px;
      opacity: 0.3;
    }
    .result-body {
      padding: 12px 14px 14px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .result-name {
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
    }
    .result-category {
      font-size: 12px;
      color: var(--gold-dark);
      font-weight: 600;
    }
    .result-price {
      margin-top: auto;
      font-size: 16px;
      font-weight: 800;
      color: var(--gold-dark);
    }
    .result-price .currency {
      font-size: 13px;
      margin-right: 4px;
    }
    .no-results {
      max-width: 600px;
      margin: 60px auto;
      padding: 40px 20px;
      text-align: center;
      background: rgba(255, 255, 255, 0.7);
      border: 2px dashed var(--border);
      border-radius: 18px;
    }
    .no-results .icon {
      font-size: 72px;
      opacity: 0.4;
      margin-bottom: 12px;
    }
    .no-results h2 {
      color: var(--text);
      margin-bottom: 8px;
    }
    .no-results p {
      color: var(--text-muted);
      margin-bottom: 18px;
    }
    .no-results a {
      display: inline-block;
      padding: 10px 24px;
      background: var(--gold);
      color: #fff;
      border-radius: 10px;
      font-weight: 700;
      text-decoration: none;
    }
    .empty-search {
      max-width: 600px;
      margin: 60px auto;
      padding: 40px 20px;
      text-align: center;
      color: var(--text-muted);
    }
    .empty-search .icon {
      font-size: 64px;
      margin-bottom: 12px;
    }
    @media (max-width: 600px) {
      .search-results {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }
      .search-hero h1 {
        font-size: 20px;
      }
      .search-form input {
        padding: 12px 14px;
        font-size: 15px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <%- include('partials/header') %>

    <main>
      <div class="search-hero">
        <h1>
          <% if (query) { %>
            نتائج البحث عن: <span class="query">"<%= query %>"</span>
          <% } else { %>
            🔍 ابحث في المتجر
          <% } %>
        </h1>
        <% if (query) { %>
          <div class="count">
            <% if (results.length === 0) { %>
              لا توجد نتائج
            <% } else if (results.length === 1) { %>
              نتيجة واحدة
            <% } else { %>
              <%= results.length %> نتيجة
            <% } %>
          </div>
        <% } %>
      </div>

      <form class="search-form" action="/search" method="get">
        <input type="text" name="q" value="<%= query %>" placeholder="اكتب اسم المنتج أو كلمة من الوصف..." autocomplete="off" autofocus />
        <button type="submit">بحث</button>
      </form>

      <% if (!query) { %>
        <div class="empty-search">
          <div class="icon">🔎</div>
          <h2>ابدأ بالكتابة</h2>
          <p>ابحث بالاسم أو بكلمة من الوصف. مثلاً: "سماعات بلوتوث"، "شاحن سريع"، "A20"</p>
        </div>
      <% } else if (results.length === 0) { %>
        <div class="no-results">
          <div class="icon">😔</div>
          <h2>لا توجد نتائج لـ "<%= query %>"</h2>
          <p>جرب كلمة مختلفة أو تحقق من الإملاء. يمكنك أيضاً تصفح الأقسام من الأسفل.</p>
          <a href="/">🏠 العودة للرئيسية</a>
        </div>
      <% } else { %>
        <div class="search-results">
          <% results.forEach(function(p) { %>
            <% const dp = displayPrice(p); %>
            <a class="result-card" href="/product/<%= p.id %>">
              <div class="result-image">
                <% if (p.image_type) { %>
                  <img src="/img/<%= p.id %>" alt="<%= p.name %>" loading="lazy" />
                <% } else { %>
                  <div class="no-image">📦</div>
                <% } %>
              </div>
              <div class="result-body">
                <div class="result-name"><%= p.name %></div>
                <div class="result-category">📂 <%= p.category_name %></div>
                <div class="result-price">
                  <%= dp.amount %>
                  <span class="currency"><%= dp.symbol %></span>
                </div>
              </div>
            </a>
          <% }); %>
        </div>
      <% } %>
    </main>

    <%- include('partials/footer') %>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>
