<%- include('partials/header') %>

<div class="breadcrumb">
  <a href="/">الرئيسية</a>
  <span class="sep">›</span>
  <span>تواصل معنا</span>
</div>

<section class="contact-page">
  <div class="contact-header">
    <h1>تواصل معنا</h1>
    <div class="gold-divider"></div>
    <p>عندك سؤال أو بدك تطلب؟ تواصل معنا عبر إحدى الطرق التالية</p>
  </div>

  <div class="contact-grid">
    <% if (settings.whatsapp_number) { %>
      <a href="https://wa.me/<%= settings.whatsapp_number.replace(/[^\d]/g, '') %>" target="_blank" rel="noopener" class="contact-card whatsapp">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074 1.488 2.095 2.896 3.122 4.647 4.092.539.307.96.491 1.291.629.517.232.988.199 1.361.12.416-.09 1.288-.527 1.47-1.035.182-.508.182-.944.127-1.035-.055-.091-.199-.149-.371-.249m.812-9.713c-4.142 0-7.494 3.353-7.494 7.495 0 1.388.363 2.717 1.027 3.84l-1.092 3.286 3.358-1.084a7.434 7.434 0 0 0 3.567.91h.004c4.142 0 7.494-3.353 7.494-7.495 0-2.003-.778-3.886-2.193-5.302a7.452 7.452 0 0 0-5.303-2.193h-.368" fill="currentColor"/></svg>
        </div>
        <div class="contact-info">
          <div class="contact-label">واتساب</div>
          <div class="contact-value" dir="ltr"><%= settings.whatsapp_number %></div>
        </div>
      </a>
    <% } %>

    <% if (settings.social_facebook || settings.social_instagram || settings.social_youtube || settings.social_twitter || settings.social_tiktok) { %>
      <div class="contact-card social-card">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/></svg>
        </div>
        <div class="contact-info">
          <div class="contact-label">تابعنا على السوشيال ميديا</div>
          <div class="social-links-large">
            <% if (settings.social_facebook) { %>
              <a href="<%= settings.social_facebook %>" target="_blank" rel="noopener" title="فيسبوك">📘 فيسبوك</a>
            <% } %>
            <% if (settings.social_instagram) { %>
              <a href="<%= settings.social_instagram %>" target="_blank" rel="noopener" title="انستغرام">📷 انستغرام</a>
            <% } %>
            <% if (settings.social_youtube) { %>
              <a href="<%= settings.social_youtube %>" target="_blank" rel="noopener" title="يوتيوب">▶️ يوتيوب</a>
            <% } %>
            <% if (settings.social_twitter) { %>
              <a href="<%= settings.social_twitter %>" target="_blank" rel="noopener" title="X">🐦 X</a>
            <% } %>
            <% if (settings.social_tiktok) { %>
              <a href="<%= settings.social_tiktok %>" target="_blank" rel="noopener" title="تيك توك">🎵 تيك توك</a>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>

    <div class="contact-card info-card">
      <div class="contact-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="currentColor"/></svg>
      </div>
      <div class="contact-info">
        <div class="contact-label">كيف تطلب؟</div>
        <div class="contact-text">
          1. تصفح الأقسام من <a href="/">الرئيسية</a><br>
          2. اختر المنتج اللي يعجبك<br>
          3. اضغط <strong>"اطلب عبر واتساب"</strong><br>
          4. رح نرد عليك بأسرع وقت ⚡
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
